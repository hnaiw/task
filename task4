void suaFile() {
    FILE *f = fopen("SO_LIEU.C", "rb+");
    if (f == NULL) {
        printf("Khong mo duoc file!\n");
        return;
    }
    char ten[50];
    printf("Nhap ten hang can sua: ");
    scanf(" %[^\n]", ten);

    Hang h;
    int found = 0;

    while (fread(&h, sizeof(Hang), 1, f)) {
        if (strcmp(h.ten_hang, ten) == 0) {
            printf("Nhap thong tin moi:\n");
            printf("Ten hang: ");
            scanf(" %[^\n]", h.ten_hang);
            printf("Don gia: ");
            scanf("%f", &h.don_gia);
            printf("So luong: ");
            scanf("%d", &h.so_luong);

            tinhtien(&h);

            fseek(f, -sizeof(Hang), SEEK_CUR);
            fwrite(&h, sizeof(Hang), 1, f);

            found = 1;
            break;
        }
    }

    if (!found) {
        printf("Khong tim thay mat hang!\n");
    }

    fclose(f);
}
void hienThiFile() {
    FILE *f = fopen("SO_LIEU.C", "rb");
    if (f == NULL) {
        printf("Khong mo duoc file!\n");
        return;
    }

    Hang h;
    int stt = 1;
    float tong = 0;

    printf("\nSO LIEU BAN HANG\n");
    printf("STT\tTen hang\tDon gia\tSo luong\tThanh tien\n");

    while (fread(&h, sizeof(Hang), 1, f)) {
        printf("%d\t%s\t%.2f\t%d\t\t%.2f\n",
               stt++, h.ten_hang, h.don_gia, h.so_luong, h.thanh_tien);
        tong += h.thanh_tien;
    }

    printf("\nTong tien: %.2f\n", tong);

    fclose(f);
}
int main() {
    int chon;

    do {
        printf("\n===== MENU =====\n");
        printf("1. Nhap so lieu ban hang\n");
        printf("2. Bo sung so lieu\n");
        printf("3. Sua thong tin mat hang\n");
        printf("4. Hien thi tep\n");
        printf("5. Ket thuc\n");
        printf("Chon: ");
        scanf("%d", &chon);

        switch (chon) {
            case 1: nhapFile(); break;
            case 2: boSungFile(); break;
            case 3: suaFile(); break;
            case 4: hienThiFile(); break;
            case 5: printf("ai doc duoc dong nay rat dep trai\n"); break;
            default: printf("Lua chon khong hop le!\n");
        }

    } while (chon != 5);

    return 0;
}

