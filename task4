#include <stdio.h>
#include <stdlib.h>

#define MAX 100

int n, m;
int A[MAX][MAX], B[MAX][MAX], C[MAX][MAX];

void taoFile() {
    FILE *f = fopen("MA_TRAN.C", "w");
    if (f == NULL) {
        printf("Khong mo duoc file!\n");
        return;
    }

    printf("Nhap n, m: ");
    scanf("%d %d", &n, &m);

    fprintf(f, "%d %d\n", n, m);
    fprintf(f, "Ma tran A\n");
    printf("Nhap ma tran A:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &A[i][j]);
            fprintf(f, "%d ", A[i][j]);
        }
        fprintf(f, "\n");
    }
    fprintf(f, "Ma tran B\n");
    printf("Nhap ma tran B:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            scanf("%d", &B[i][j]);
            fprintf(f, "%d ", B[i][j]);
        }
        fprintf(f, "\n");
    }

    fclose(f);
}
void docFile() {
    FILE *f = fopen("MA_TRAN.C", "r");
    if (f == NULL) {
        printf("Khong mo duoc file!\n");
        return;
    }

    fscanf(f, "%d %d", &n, &m);

    char temp[50];
    fgets(temp, sizeof(temp), f); 
    fgets(temp, sizeof(temp), f);
    for (int i = 0; i < n; i++)
        for (int j = 0; j < m; j++)
            fscanf(f, "%d", &A[i][j]);
    fgets(temp, sizeof(temp), f); 
    fgets(temp, sizeof(temp), f); 
    for (int i = 0; i < n; i++)
        for (int j = 0; j < m; j++)
            fscanf(f, "%d", &B[i][j]);

    fclose(f);

    printf("\nMa tran A:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++)
            printf("%d ", A[i][j]);
        printf("\n");
    }

    printf("\nMa tran B:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++)
            printf("%d ", B[i][j]);
        printf("\n");
    }
}
void ghiMaTranC() {
    FILE *f = fopen("MA_TRAN.C", "a");
    if (f == NULL) {
        printf("Khong mo duoc file!\n");
        return;
    }
    for (int i = 0; i < n; i++)
        for (int j = 0; j < m; j++)
            C[i][j] = A[i][j] + B[i][j];
    fprintf(f, "Ma tran C = A + B\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++)
            fprintf(f, "%d ", C[i][j]);
        fprintf(f, "\n");
    }

    fclose(f);

    printf("\nDa ghi ma tran C vao file!\n");
}

int main() {
    int chon;

    do {
        printf("\n===== MENU =====\n");
        printf("1. Tao & doc tep MA_TRAN.C\n");
        printf("2. Ghi ma tran C vao cuoi tep\n");
        printf("3. Ket thuc\n");
        printf("Chon: ");
        scanf("%d", &chon);

        switch (chon) {
            case 1:
                taoFile();
                docFile();
                break;
            case 2:
                ghiMaTranC();
                break;
            case 3:
                printf("toimetmoiqua\n");
                break;
            default:
                printf("Khong hop le!\n");
        }

    } while (chon != 3);

    return 0;
}
