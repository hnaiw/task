#include <stdio.h>
#include <stdlib.h>
#include <string.h>
typedef struct {
    char ten_hang[50];
    float don_gia;
    int so_luong;
    float thanh_tien;
} Hang;
void tinhtien(Hang *h) {
    h->thanh_tien = h->don_gia * h->so_luong;
}
void nhapFile() {
    FILE *f = fopen("SO_LIEU.C", "wb");
    if (f == NULL) {
        printf("Khong mo duoc file!\n");
        return;
    }

    int n;
    printf("Nhap so mat hang: ");
    scanf("%d", &n);

    Hang h;
    for (int i = 0; i < n; i++) {
        printf("\nMat hang %d:\n", i + 1);
        printf("Ten hang: ");
        scanf(" %[^\n]", h.ten_hang);
        printf("Don gia: ");
        scanf("%f", &h.don_gia);
        printf("So luong: ");
        scanf("%d", &h.so_luong);

        tinhtien(&h);
        fwrite(&h, sizeof(Hang), 1, f);
    }

    fclose(f);
}

void boSungFile() {
    FILE *f = fopen("SO_LIEU.C", "ab");
