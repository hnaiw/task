#include <stdio.h>
#include <stdlib.h> 
#include <string.h>
struct SinhVien{
    char Ho_ten[50];
    int Tuoi;
    float Diem_TB;
};
struct Node{
    struct SinhVien data;
    struct Node *next;
};
typedef struct Node Node;
Node* createNode(){
    Node* newNode = (Node*)malloc(sizeof(Node));
    printf("Nhap ho ten: ");
    fflush(stdin);
    gets(newNode->data.Ho_ten);
    printf("Nhap tuoi: ");
    scanf("%d",&newNode->data.Tuoi);
    printf("Nhap diem TB: ");
    scanf("%f",&newNode->data.Diem_TB);
    newNode->next = NULL;
    return newNode;
}
void taoDanhSach(Node **head){
    int n;
    printf("Nhap so sinh vien: ");
    scanf("%d",&n);
    for(int i=0;i<n;i++){
        printf("\nSinh vien %d\n",i+1);
        Node *newNode = createNode();
        if(*head == NULL)
            *head = newNode;
        else{
            Node *temp = *head;
            while(temp->next != NULL)
                temp = temp->next;
            temp->next = newNode;
        }
    }
}
void hienThi(Node *head){
    printf("\nDANH SACH SINH VIEN\n");
    printf("%-5s %-25s %-10s %-10s\n","STT","Ho ten","Tuoi","Diem TB");
    int stt = 1;
    while(head != NULL){
        printf("%-5d %-25s %-10d %-10.2f\n",
               stt,
               head->data.Ho_ten,
               head->data.Tuoi,
               head->data.Diem_TB);
        stt++;
        head = head->next;
    }
}
void chenSinhVien(Node *head){
    char ten[50];
    printf("Nhap ten sinh vien muon chen sau: ");
    fflush(stdin);
    gets(ten);
    while(head != NULL){
        if(strcmp(head->data.Ho_ten,ten)==0){
            printf("Nhap sinh vien moi:\n");
            Node *newNode = createNode();
            newNode->next = head->next;
            head->next = newNode;
            printf("Da chen thanh cong!\n");
            return;
        }
        head = head->next;
    }
    printf("Khong tim thay sinh vien!\n");
}
Node* xoaSinhVien(Node *head){
    char ten[50];
    printf("Nhap ten sinh vien muon xoa: ");
    fflush(stdin);
    gets(ten);
    Node *temp = head;
    Node *prev = NULL;
    while(temp != NULL){
        if(strcmp(temp->data.Ho_ten,ten)==0){
            if(prev == NULL)
                head = temp->next;
            else
                prev->next = temp->next;
            free(temp);
            printf("Da xoa sinh vien!\n");
            return head;
        }
        prev = temp;
        temp = temp->next;
    }
    printf("Khong tim thay sinh vien!\n");
    return head;
}
void suaSinhVien(Node *head){
    char ten[50];
    printf("Nhap ten sinh vien muon sua: ");
    fflush(stdin);
    gets(ten);
    while(head != NULL){
        if(strcmp(head->data.Ho_ten,ten)==0){
            printf("Nhap ten moi: ");
            gets(head->data.Ho_ten);
            printf("Nhap tuoi moi: ");
            scanf("%d",&head->data.Tuoi);
            printf("Nhap diem TB moi: ");
            scanf("%f",&head->data.Diem_TB);
            printf("Da sua thanh cong!\n");
            return;
        }
        head = head->next;
    }
    printf("Khong tim thay sinh vien!\n");
}
int main(){
    Node *head = NULL;
    int choice;
    do{
        printf("\n===== MENU =====\n");
        printf("1. Tao danh sach sinh vien\n");
        printf("2. Hien thi danh sach sinh vien\n");
        printf("3. Chen them sinh vien\n");
        printf("4. Xoa mot sinh vien\n");
        printf("5. Sua mot sinh vien\n");
        printf("6. Ket thuc\n");
        printf("Nhap lua chon: ");
        scanf("%d",&choice);
        switch(choice){
            case 1:
                taoDanhSach(&head);
                break;
            case 2:
                hienThi(head);
                break;
            case 3:
                chenSinhVien(head);
                break;
            case 4:
                head = xoaSinhVien(head);
                break;
            case 5:
                suaSinhVien(head);
                break;
        }
    }while(choice != 6);
}
